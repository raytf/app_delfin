{
  "name": "delfin",
  "version": "0.1.0",
  "description": "Delfin — a live voice-based study assistant that understands your screen context. Fully local, private, no API costs.",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:sidecar": "node scripts/run-sidecar.mjs",
    "dev:litert-cpp": "node scripts/litert-cpp-proxy.mjs",
    "dev:full": "concurrently --names \"sidecar,electron\" --prefix-colors \"cyan,magenta\" \"npm run dev:sidecar\" \"npm run dev\"",
    "dev:mock": "concurrently --names \"mock,electron\" --prefix-colors \"yellow,magenta\" \"node scripts/mock-sidecar.js\" \"npm run dev\"",
    "build": "electron-vite build && npx esbuild scripts/litert-cpp-proxy.mjs --bundle --platform=node --format=esm --outfile=out/main/litert-cpp-proxy.mjs --external:electron --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
    "postbuild": "npm run check:vad-runtime",
    "preview": "electron-vite preview",
    "setup": "npm run init:env && npm run setup:sidecar && npm run download:models && npm run check:env",
    "setup:sidecar": "node scripts/setup-sidecar.mjs",
    "setup:litert-cpp": "node scripts/setup-litert-cpp.mjs",
    "build:litert-cpp-bridge": "node scripts/build-litert-cpp-bridge.mjs",
    "init:env": "node scripts/init-env.mjs",
    "download:models": "node scripts/download-models.mjs",
    "download:ci-bridge:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\windows\\download-ci-bridge.ps1",
    "check:env": "node scripts/check-env.mjs",
    "check:vad-runtime": "node scripts/check-vad-runtime.mjs",
    "setup-check:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\windows\\setup-check.ps1",
    "voice:list": "node scripts/piper-voice.mjs list",
    "voice:use": "node scripts/piper-voice.mjs use",
    "voice:install": "node scripts/piper-voice.mjs install",
    "benchmark:litert": "node scripts/run-benchmark.mjs --backend litert --runs 5",
    "benchmark:litert-cpp": "node scripts/run-benchmark.mjs --backend litert-cpp --runs 5",
    "test:ci-bridge:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\windows\\test-ci-bridge.ps1",
    "test": "vitest run",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir"
  },
  "build": {
    "appId": "com.delfin.desktop",
    "productName": "Delfin",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "out/main/litert-cpp-proxy.mjs",
        "to": "litert-cpp-proxy.mjs"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "extraResources": [
        {
          "from": "bin/delfin_litert_bridge",
          "to": "delfin_litert_bridge"
        },
        {
          "from": "bin/libGemmaModelConstraintProvider.dylib",
          "to": "libGemmaModelConstraintProvider.dylib"
        },
        {
          "from": "bin/piper",
          "to": "bin/piper"
        },
        {
          "from": "models/piper",
          "to": "models/piper"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "extraResources": [
        {
          "from": "bin/delfin_litert_bridge.exe",
          "to": "delfin_litert_bridge.exe"
        },
        {
          "from": "bin/libGemmaModelConstraintProvider.dll",
          "to": "libGemmaModelConstraintProvider.dll"
        },
        {
          "from": "bin/piper",
          "to": "bin/piper"
        },
        {
          "from": "models/piper",
          "to": "models/piper"
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "Education",
      "extraResources": [
        {
          "from": "bin/delfin_litert_bridge",
          "to": "delfin_litert_bridge"
        },
        {
          "from": "bin/libGemmaModelConstraintProvider.so",
          "to": "libGemmaModelConstraintProvider.so"
        },
        {
          "from": "bin/piper",
          "to": "bin/piper"
        },
        {
          "from": "models/piper",
          "to": "models/piper"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.0.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.2",
    "vite": "^7.3.2",
    "vite-plugin-static-copy": "^4.0.1",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@ricky0123/vad-web": "^0.0.30",
    "dotenv": "^17.4.1",
    "lucide-react": "^1.8.0",
    "onnxruntime-web": "^1.17.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.1",
    "ws": "^8.18.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.0"
  }
}
