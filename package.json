{
  "name": "screen-copilot",
  "version": "0.0.0",
  "description": "Local AI desktop sidebar for screen analysis",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:full": "concurrently --names \"sidecar,electron\" --prefix-colors \"cyan,magenta\" \"cd sidecar && .venv/bin/uvicorn server:app --host 0.0.0.0 --port 8321\" \"npm run dev\"",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "setup:sidecar": "cd sidecar && python3 -m venv .venv && .venv/bin/pip install -r requirements.txt"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.0"
  }
}
