{
  "name": "delfin",
  "version": "0.0.1",
  "description": "Delfin — a live voice-based study assistant that understands your screen context. Fully local, private, no API costs.",
  "main": "dist/electron/main/index.js",
  "scripts": {
    "dev": "concurrently --names \"backend,frontend\" --prefix-colors \"cyan,magenta\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "electron-vite dev",
    "dev:backend": "tsx watch sidecar/src/index.ts",
    "dev:mock": "concurrently --names \"mock,frontend\" --prefix-colors \"yellow,magenta\" \"node scripts/mock-sidecar.js\" \"npm run dev:frontend\"",
    "dev:sidecar": "tsx watch sidecar/src/index.ts",
    "dev:sidecar-old": "cd sidecar-old && uvicorn server:app --host 0.0.0.0 --port 8321",
    "build": "npm run build:frontend && npm run build:sidecar",
    "build:frontend": "electron-vite build",
    "build:sidecar": "tsc -p sidecar/tsconfig.json",
    "postbuild": "npm run check:vad-runtime",
    "preview": "electron-vite preview",
    "setup": "npm run setup:env && npm run setup:litert-cpp && npm run check:env",
    "setup:env": "node scripts/init-env.mjs",
    "setup:litert-cpp": "node scripts/setup-litert-cpp.mjs",
    "setup:sidecar": "node scripts/setup-sidecar.mjs",
    "bridge:build": "node scripts/build-litert-cpp-bridge.mjs",
    "download:models": "node scripts/download-models.mjs",
    "download:bridge:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\windows\\download-ci-bridge.ps1",
    "check:env": "node scripts/check-env.mjs",
    "check:vad-runtime": "node scripts/check-vad-runtime.mjs",
    "check:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\windows\\setup-check.ps1",
    "voice:list": "node scripts/piper-voice.mjs list",
    "voice:use": "node scripts/piper-voice.mjs use",
    "voice:install": "node scripts/piper-voice.mjs install",
    "benchmark:litert-cpp": "node scripts/run-benchmark.mjs --backend litert-cpp --runs 5",
    "benchmark:litert-py": "node scripts/run-benchmark.mjs --backend litert --runs 5",
    "benchmark:sweep": "node scripts/benchmark-sweep.mjs",
    "test:bridge:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\windows\\test-ci-bridge.ps1",
    "test": "vitest run",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir"
  },
  "build": {
    "appId": "com.delfin.desktop",
    "productName": "Delfin",
    "directories": {
      "output": "dist/installers"
    },
    "files": [
      "dist/electron/**/*",
      "dist/sidecar/**/*"
    ],
    "extraResources": [],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "extraResources": [
        {
          "from": "bin/delfin_litert_bridge",
          "to": "delfin_litert_bridge"
        },
        {
          "from": "bin/libGemmaModelConstraintProvider.dylib",
          "to": "libGemmaModelConstraintProvider.dylib"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "extraResources": [
        {
          "from": "bin/delfin_litert_bridge.exe",
          "to": "delfin_litert_bridge.exe"
        },
        {
          "from": "bin/libGemmaModelConstraintProvider.dll",
          "to": "libGemmaModelConstraintProvider.dll"
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "Education",
      "extraResources": [
        {
          "from": "bin/delfin_litert_bridge",
          "to": "delfin_litert_bridge"
        },
        {
          "from": "bin/libGemmaModelConstraintProvider.so",
          "to": "libGemmaModelConstraintProvider.so"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.0.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^7.3.2",
    "vite-plugin-static-copy": "^4.0.1",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@ricky0123/vad-web": "^0.0.30",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^1.8.0",
    "onnxruntime-web": "^1.17.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.1",
    "uuid": "^14.0.0",
    "ws": "^8.18.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.0"
  }
}
