# ============================================================
# Delfin — Environment Configuration
# Copy this file to .env and adjust for your machine.
# ============================================================

# --- Model ---
# Switch to gemma-4-E4B-it-litert-lm for 32 GB machines
MODEL_REPO=litert-community/gemma-4-E2B-it-litert-lm
# MODEL_FILE is legacy — active setup scripts use MODEL_REPO for HuggingFace downloads
MODEL_FILE=gemma-4-E2B-it.litertlm
# HuggingFace commit SHA pinned to match LITERT_LM_REF in scripts/setup-litert-cpp.mjs.
# Must be bumped together with LITERT_LM_REF when upgrading the bridge.
# Overrides the default pin in setup-litert-cpp.mjs when set.
# Bump procedure: README.md §Updating the LiteRT-LM bridge.
# After bumping + CI rebuild, `npm run setup:litert-cpp` auto-detects the stale
# local bridge via bin/bridge.version and re-downloads — no extra flags needed.
#MODEL_REVISION=84b6978eff6e4eea02825bc2ee4ea48579f13109

# --- Sidecar ---
# Bind to 0.0.0.0 so Windows (host) can reach WSL2
SIDECAR_HOST=0.0.0.0
SIDECAR_PORT=8321

# --- Electron ---
# Base URL of the sidecar; the WebSocket endpoint (ws://…/ws) is derived from it.
# On WSL2, if localhost fails, use the WSL2 IP (run: hostname -I).
SIDECAR_URL=http://localhost:8321

# --- Inference ---
# Options: CPU (default), GPU (Metal on Mac, OpenCL on Linux)
LITERT_BACKEND=CPU
LITERT_CACHE_DIR=/tmp/litert-cache
# Visual tokens per image. Lower = faster prefill. Range: 70-1120
VISION_TOKEN_BUDGET=280
# Max image width in pixels before resize. 512 is good for slides.
MAX_IMAGE_WIDTH=512
# Audio backend for the LiteRT-LM engine. In practice always CPU.
LITERT_AUDIO_BACKEND=CPU

# --- Voice input ---
# Set to true to enable always-on VAD mic when a session is active.
# The renderer reads this at startup via the preload script (no VITE_ prefix needed).
VOICE_ENABLED=true

# --- LiteRT-LM C++ bridge ---
# `npm run dev:backend` starts the TypeScript sidecar (sidecar/src/), which
# spawns the C++ bridge. `LITERT_CPP_BIN` must point at the Delfin JSONL/stdio
# bridge built from `litert-cpp-bridge/` (delfin_litert_bridge[.exe]); the
# upstream `litert_lm_main` demo binary does NOT speak the Delfin JSONL protocol.
# `npm run setup:litert-cpp` writes LITERT_CPP_BIN / LITERT_CPP_MODEL for you.
# LITERT_CPP_BIN=./bin/delfin_litert_bridge.exe
# LITERT_CPP_MODEL=./models/gemma-4-E2B-it.litertlm
# Optional: override the GitHub repo used when setup:litert-cpp downloads bridge
# workflow artifacts. If unset, setup infers it from the git remote origin.
# LITERT_CPP_BRIDGE_REPO=owner/repo

# --- TTS ---
# TypeScript sidecar TTS backend:
#   piper — repo-local Piper runtime (default; provisioned by setup:litert-cpp)
#   none  — disable sidecar TTS; the renderer falls back to browser Web Speech
TTS_BACKEND=piper
# Renderer TTS playback on/off (read by the Electron main process).
TTS_ENABLED=true
# Optional low-latency Piper chunking for long model text without punctuation.
# Completed sentences always flush first; these only tune soft partial flushes.
# TTS_SOFT_MIN_CHARS=80
# TTS_SOFT_MAX_CHARS=180
# Piper runtime + voice — written automatically by `npm run setup:litert-cpp`.
# Swap voices with `npm run voice:list` / `voice:use` / `voice:install`.
# PIPER_SAMPLE_RATE is optional when PIPER_CONFIG contains audio.sample_rate.
# PIPER_BIN=./bin/piper/venv/Scripts/piper.exe
# PIPER_MODEL=./models/piper/en_US-hfc_female-medium.onnx
# PIPER_CONFIG=./models/piper/en_US-hfc_female-medium.onnx.json
# PIPER_SAMPLE_RATE=22050

# --- TTS (deprecated Python sidecar — sidecar-old/) ---
# The Python sidecar's TTS_BACKEND also accepts kokoro / mlx / web-speech; the
# TypeScript sidecar treats any non-`piper` value as `none`. These apply only
# when running `npm run dev:sidecar-old`.
# KOKORO_VOICE=af_heart
# KOKORO_SPEED=1.1
# KOKORO_MODEL_PATH=kokoro-v1.0.onnx
# KOKORO_VOICES_PATH=voices-v1.0.bin
