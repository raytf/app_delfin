# ============================================================
# Delfin — Environment Configuration
# Copy this file to .env and adjust for your machine.
# ============================================================

# --- Model ---
# Switch to gemma-4-E4B-it-litert-lm for 32 GB machines
MODEL_REPO=litert-community/gemma-4-E2B-it-litert-lm
# MODEL_FILE is legacy — active setup scripts use MODEL_REPO for HuggingFace downloads
MODEL_FILE=gemma-4-E2B-it.litertlm
# HuggingFace commit SHA pinned to match LITERT_LM_REF in scripts/setup-litert-cpp.mjs.
# Must be bumped together with LITERT_LM_REF when upgrading the bridge.
# Overrides the default pin in setup-litert-cpp.mjs when set.
#MODEL_REVISION=84b6978eff6e4eea02825bc2ee4ea48579f13109

# --- Sidecar ---
# Bind to 0.0.0.0 so Windows (host) can reach WSL2
SIDECAR_HOST=0.0.0.0
SIDECAR_PORT=8321

# --- Electron ---
# On WSL2 if localhost fails, use WSL2 IP (run: hostname -I)
SIDECAR_WS_URL=ws://localhost:8321/ws

# --- Inference ---
# Backend to spawn on startup. Options: litert (Python sidecar), litert-cpp (native bridge)
# Dev default is litert for backward compat. litert-cpp-primary-backend-migration-spec.md
# (M5a) will flip this to litert-cpp on all platforms once runtime validation completes.
INFERENCE_BACKEND=litert
# Options: CPU (default), GPU (Metal on Mac, OpenCL on Linux)
LITERT_BACKEND=CPU
LITERT_CACHE_DIR=/tmp/litert-cache
# Visual tokens per image. Lower = faster prefill. Range: 70-1120
VISION_TOKEN_BUDGET=280
# Max image width in pixels before resize. 512 is good for slides.
MAX_IMAGE_WIDTH=512
# Audio backend for the LiteRT-LM engine. In practice always CPU.
LITERT_AUDIO_BACKEND=CPU

# --- Voice input ---
# Set to true to enable always-on VAD mic when a session is active.
# The renderer reads this at startup via the preload script (no VITE_ prefix needed).
VOICE_ENABLED=true

# --- LiteRT-LM C++ bridge (native backend) ---
# Run `npm run dev:backend` to start the Delfin-compatible WebSocket proxy.
# `LITERT_CPP_BIN` must point at the Delfin JSONL/stdio bridge built from
# `native/litert-cpp-bridge/` (delfin_litert_bridge[.exe]). The upstream
# `litert_lm_main` demo binary does NOT speak the Delfin JSONL protocol and
# cannot be used in its place.
# LITERT_CPP_BIN=./bin/delfin_litert_bridge.exe
# LITERT_CPP_MODEL=./models/gemma-4-E2B-it.litertlm
# Optional: override GitHub repo used when setup:litert-cpp downloads bridge
# workflow artifacts. If unset, setup infers this from git remote origin.
# LITERT_CPP_BRIDGE_REPO=owner/repo
# Optional off-Python TTS for the LiteRT C++ proxy path.
# `none` keeps today's renderer Web Speech fallback.
# `piper` makes `scripts/litert-cpp-proxy.mjs` emit `audio_*` messages directly.
# `npm run setup:litert-cpp` bootstraps a repo-local Piper runtime via pinned
# `piper-tts` and writes `PIPER_BIN` automatically. To swap voices, use
# `npm run voice:list`, `npm run voice:use -- <voice-name>`, or
# `npm run voice:install -- <hf-path> --use`. `PIPER_SAMPLE_RATE` is optional
# when `PIPER_CONFIG` contains `audio.sample_rate`.
# LITERT_CPP_TTS_BACKEND=none
# Optional low-latency Piper chunking for long model text without punctuation.
# Completed sentences always flush first; these only control soft partial flushes.
# LITERT_CPP_TTS_SOFT_MIN_CHARS=80
# LITERT_CPP_TTS_SOFT_MAX_CHARS=180
# PIPER_BIN=./bin/piper/venv/Scripts/piper.exe
# PIPER_MODEL=./models/piper/en_US-hfc_female-medium.onnx
# PIPER_CONFIG=./models/piper/en_US-hfc_female-medium.onnx.json
# PIPER_SAMPLE_RATE=22050

# --- TTS (output) ---
TTS_ENABLED=true
# Options: web-speech (zero-dep, client-side), kokoro (cross-platform server-side), mlx (macOS Apple Silicon only)
# When TTS_BACKEND=kokoro, the pipeline auto-selects the best backend:
#   - macOS Apple Silicon → mlx-audio (GPU), falls back to ONNX (CPU)
#   - Linux / WSL2 → ONNX (CPU)
TTS_BACKEND=kokoro
# Kokoro voice name (default: af_heart). See kokoro-onnx docs for available voices.
KOKORO_VOICE=af_heart
# TTS speed multiplier (default: 1.1). Parlor uses 1.1 for natural pace.
KOKORO_SPEED=1.1
# Kokoro model files — only needed when TTS_BACKEND=kokoro.
# If these paths are empty or the files don't exist, models are auto-downloaded
# from HuggingFace (fastrtc/kokoro-onnx). Set absolute paths to use local files.
# KOKORO_MODEL_PATH=kokoro-v1.0.onnx
# KOKORO_VOICES_PATH=voices-v1.0.bin
